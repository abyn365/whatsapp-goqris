# Admin WhatsApp phone number (in international format without +, e.g. 6281234567890)
ADMIN_NUMBER=6281234567890

# Default Static QRIS Payload string
# (You can also set/update this live by sending a static QRIS image to the bot)
DEFAULT_STATIC_QRIS=00020101021126680016ID.CO.QRIS.WWW01189360091400000000000215ID10265535641090303A0151440014ID.LINKAJA.WWW01189360091400000000005204581253033605802ID5910ABYN.XYZ, 6013KOTA JAKARTA 61051234562070703A016304C20A

# Store Name displayed on invoices
STORE_NAME=ABYN.XYZ DIGITAL & KREATIF

# Command Prefix for WhatsApp commands (default: !)
BOT_PREFIX=!

# Database file location
DB_PATH=./data/qris_bot.db
